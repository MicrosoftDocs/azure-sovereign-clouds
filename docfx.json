{
  "build": {
    "content": [
      {
        "src" : "articles",
        "files": [
          "**/*.md",
          "**/*.yml"
        ],
        "exclude": [
          "**/obj/**",
          "**/includes/**",
          "_themes/**",
          "**/docfx.json",
          "_repo.en-us/**",
          "README.md",
          "LICENSE",
          "LICENSE-CODE",
          "ThirdPartyNotices.md",
          "SECURITY.md"
        ]
      },
      {
        "files": [
          "toc.yml"
        ],
        "src": "breadcrumb",
        "dest": "breadcrumb"
      }      
    ],
    "resource": [
      {
        "files": [
          "**/*.png",
          "**/*.jpg",
          "**/*.svg"
        ],
        "exclude": [
          "**/obj/**",
          "**/includes/**",
          "_themes/**",
          "**/docfx.json",
          "_repo.en-us/**"
        ]
      }
    ],
    "overwrite": [],
    "externalReference": [],
    "globalMetadata": {
      "uhfHeaderId": "Azure",
      "feedback_system": "Standard",
      "breadcrumb_path": "/azure/azure-sovereign-clouds/breadcrumb/toc.json",
      "permissioned-type": "public",
      "manager": "lizross",
      "recommendations": true
    },
    "fileMetadata": {
      "ms.service": {
        "**/*.md": "azure",
        "articles/**/*.md": "azure"
      }
    },
    "template": []
  }
}
